		formatString: 0.00
		lineageTag: d61b5d1d-49f4-4aa7-99ba-208ecbf17c3c

	measure 'Average Wind %' = AVERAGEX('df_fuel_ckan','df_fuel_ckan'[WIND_perc] + 'df_fuel_ckan'[Average embedded wind %])
		formatString: 0.00
		lineageTag: 4d23e453-b846-462a-9f80-e878e12f119f

	measure 'Average embedded wind %' = AVERAGE('df_fuel_ckan'[WIND_EMB_perc])
		formatString: 0.00
		lineageTag: e5d60049-063c-49b8-b5d8-f1c9efd1c9d5

	measure 'Renewable Energy GWh' =
			
			SUMX(
			    'df_fuel_ckan',
			    'df_fuel_ckan'[RENEWABLE] * 0.5 / 1000   // MW × 0.5 hours = MWh → /1000 = GWh
			)
		lineageTag: fcdf1075-cadb-4336-b888-c61e39b22b30

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'YoY % Change Renewable GWh' = ```
			
			    VAR CurrentGWh = [Renewable Energy GWh]
			    VAR PreviousGWh = CALCULATE([Renewable Energy GWh], SAMEPERIODLASTYEAR('Calendar'[Date]))
			    RETURN
			         IF(
			           NOT ISBLANK(PreviousGWh),
			        DIVIDE(CurrentGWh - PreviousGWh, PreviousGWh) * 100,
			        BLANK()
			         )
			```
		lineageTag: c94fcf1e-0b15-4d67-b30f-9fef3c71a877

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Average Carbon intensity' = AVERAGE('df_fuel_ckan'[CARBON_INTENSITY])
		formatString: 0.00
		lineageTag: 5427cc0d-d619-4a20-a4b4-52f559c34ec4

	measure 'Total Generation' = SUMX('df_fuel_ckan',('df_fuel_ckan'[GENERATION]*0.5)/1000)
		lineageTag: 6b9836bf-9ab5-4418-a19a-ddb99427d688

		annotation PBI_FormatHint = {"isGeneralNumber":true}

